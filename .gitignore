# Castellan — Ignore Rules

# Python & Backend
backend/env/
backend/__pycache__/
backend/uploads/*
!backend/uploads/.gitkeep
backend/*.pyc
backend/.pytest_cache/
backend/.venv/
backend/venv/

# Node & Frontend
frontend/node_modules/
frontend/dist/
# frontend/.env (Uncommented at user request)
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*

# Git Submodules / Repos (if we want to push them as code)
